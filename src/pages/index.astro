---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/layout/Header.astro'
import Sidebar from '../components/layout/Sidebar.astro'
import MapaView from '../components/views/MapaView.astro'
import GrupoView from '../components/views/GrupoView.astro'
import FichaView from '../components/views/FichaView.astro'
import ConceptGraph from '../components/graph/ConceptGraph.astro'

import {
  getGrupos,
  getTerminos,
  getTerminosByGrupo,
  getRelacionados,
  getGrupoById,
  getRelacionesByTermino,
} from '../lib/glosario'

import '../styles/global.css'

const grupos   = getGrupos()
const terminos = getTerminos()

// Pre-compute per-group terminos map
const terminosByGrupo: Record<string, typeof terminos> = {}
grupos.forEach(g => { terminosByGrupo[g.id] = getTerminosByGrupo(g.id) })

// Pre-compute search data for client
const searchData = terminos.map(t => ({
  id:             t.id,
  nombre:         t.nombre,
  tipo:           t.tipo,
  grupo:          t.grupo,
  definicionCorta: t.definicionCorta,
}))
---

<BaseLayout>
  <div class="flex flex-col h-screen overflow-hidden">
    <Header />

    <div class="flex flex-1 min-h-0">
      <Sidebar grupos={grupos} />

      <!-- Main content area -->
      <main class="flex-1 flex flex-col min-h-0 overflow-hidden">

        <!-- ── Vista: Mapa ─────────────────────────────────── -->
        <div id="view-mapa" class="view active">
          <MapaView grupos={grupos} />
          <ConceptGraph />
        </div>

        <!-- ── Vista: Grupos ──────────────────────────────── -->
        <div id="view-grupos" class="view">
          <GrupoView grupos={grupos} terminosByGrupo={terminosByGrupo} />
        </div>

        <!-- ── Vista: Ficha ───────────────────────────────── -->
        <div id="view-ficha" class="view overflow-y-auto">
          {terminos.map(t => (
            <FichaView
              termino={t}
              grupo={getGrupoById(t.grupo)}
              relacionados={getRelacionados(t.id)}
              relaciones={getRelacionesByTermino(t.id)}
            />
          ))}
        </div>

      </main>
    </div>
  </div>

  <!-- ── Search overlay ──────────────────────────────────── -->
  <div id="search-overlay" role="dialog" aria-label="Búsqueda de términos" aria-modal="true">
    <div
      class="w-full max-w-xl rounded-2xl overflow-hidden"
      style="background: var(--bg-card); border: 1px solid var(--border); box-shadow: 0 0 40px rgba(0,229,255,0.15);"
    >
      <div class="flex items-center gap-3 px-4 py-3" style="border-bottom: 1px solid var(--border);">
        <svg width="16" height="16" fill="none" stroke="var(--text-muted)" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder="Buscar términos..."
          class="flex-1 bg-transparent outline-none text-sm"
          style="color: var(--text-primary);"
          autocomplete="off"
          spellcheck="false"
        />
        <kbd
          class="px-1.5 py-0.5 rounded text-xs font-mono"
          style="background: var(--bg-secondary); border: 1px solid var(--border); color: var(--text-muted);"
        >
          Esc
        </kbd>
      </div>
      <div id="search-results" class="overflow-y-auto" style="max-height: 400px;"></div>
    </div>
  </div>

</BaseLayout>

<!-- ── Client-side SPA logic ────────────────────────────────────────── -->
<script define:vars={{ searchData, grupoIds: grupos.map(g => g.id) }}>

  // ── State ─────────────────────────────────────────────────────────────────

  let currentView   = 'mapa'  // 'mapa' | 'grupos' | 'ficha'
  let currentGrupoId = null   // active group in grupos view
  let currentFichaId = null   // active term ficha

  // ── Core navigation ───────────────────────────────────────────────────────

  function showView(viewId) {
    document.querySelectorAll('.view').forEach(v => {
      v.classList.remove('active')
      v.classList.add('hidden-view')
    })
    const el = document.getElementById(`view-${viewId}`)
    if (el) {
      el.classList.remove('hidden-view')
      el.classList.add('active')
    }
  }

  function navigate(view, id = null) {
    currentView = view

    if (view === 'mapa') {
      showView('mapa')
      currentGrupoId = null
      currentFichaId = null
      updateNavActive('mapa')
      window.history.pushState({}, '', '#mapa')

    } else if (view === 'grupos') {
      showView('grupos')
      currentFichaId = null
      updateNavActive('grupos')

      if (id) {
        currentGrupoId = id
        showGrupoPanel(id)
        window.history.pushState({}, '', `#grupos/${id}`)
      } else {
        currentGrupoId = null
        showGruposGrid()
        window.history.pushState({}, '', '#grupos')
      }

    } else if (view === 'ficha') {
      currentFichaId = id
      showView('ficha')
      updateNavActive(null)
      window.history.pushState({}, '', `#termino/${id}`)
      showFichaPanel(id)
    }

    updateSidebarActive()
  }

  // Expose globally for D3 graph click handler
  window.__bioNavigate = navigate

  // ── View helpers ──────────────────────────────────────────────────────────

  function showGruposGrid() {
    document.getElementById('grupos-grid')?.classList.remove('hidden')
    document.querySelectorAll('.grupo-panel').forEach(p => {
      p.classList.add('hidden')
      p.classList.remove('flex')
    })
  }

  function showGrupoPanel(grupoId) {
    document.getElementById('grupos-grid')?.classList.add('hidden')
    document.querySelectorAll('.grupo-panel').forEach(p => {
      p.classList.add('hidden')
      p.classList.remove('flex')
    })
    const panel = document.getElementById(`grupo-panel-${grupoId}`)
    if (panel) {
      panel.classList.remove('hidden')
      panel.classList.add('flex')
      // Trigger stagger animations
      panel.querySelectorAll('.stagger-item').forEach((el, i) => {
        el.style.animationDelay = `${i * 0.06}s`
        el.style.opacity = '0'
        void el.offsetWidth // reflow
        el.style.animation = 'none'
        void el.offsetWidth
        el.style.animation = ''
      })
    }
  }

  function showFichaPanel(fichaId) {
    document.querySelectorAll('.ficha-panel').forEach(p => p.classList.add('hidden'))
    const panel = document.getElementById(`ficha-${fichaId}`)
    if (panel) {
      panel.classList.remove('hidden')
      panel.scrollTop = 0
    }
  }

  // ── Active states ─────────────────────────────────────────────────────────

  function updateNavActive(which) {
    document.querySelectorAll('.nav-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.nav === which)
    })
  }

  function updateSidebarActive() {
    document.querySelectorAll('.sidebar-group-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.grupoBtn === currentGrupoId)
    })
  }

  // ── Event delegation ──────────────────────────────────────────────────────

  document.addEventListener('click', event => {
    const target = event.target.closest('[data-action]')
    if (!target) return

    const action  = target.dataset.action
    const view    = target.dataset.view
    const grupoId = target.dataset.grupoId
    const id      = target.dataset.id

    if (action === 'navigate') {
      if (grupoId) {
        navigate('grupos', grupoId)
      } else if (view) {
        navigate(view)
      }
    }

    if (action === 'navigate-ficha') {
      navigate('ficha', id)
    }

    if (action === 'show-grupos-grid') {
      navigate('grupos')
    }

    if (action === 'export-ficha') {
      exportFicha(id, target.dataset.nombre, target)
    }

    if (action === 'toggle-dominado') {
      window.__toggleDominado?.(id)
    }
  })

  // term-link clicks (rendered via parseLinks)
  document.addEventListener('click', event => {
    const target = event.target.closest('.term-link')
    if (!target) return
    navigate('ficha', target.dataset.id)
  })

  // ── Search (Cmd+K) ────────────────────────────────────────────────────────

  const overlay     = document.getElementById('search-overlay')
  const searchInput = document.getElementById('search-input')
  const searchResultsEl = document.getElementById('search-results')
  let selectedIdx   = -1
  let filteredResults = []

  function openSearch() {
    overlay?.classList.add('open')
    searchInput?.focus()
    renderSearchResults('')
  }

  function closeSearch() {
    overlay?.classList.remove('open')
    if (searchInput) searchInput.value = ''
    selectedIdx = -1
  }

  document.getElementById('search-trigger')?.addEventListener('click', openSearch)

  overlay?.addEventListener('click', event => {
    if (event.target === overlay) closeSearch()
  })

  document.addEventListener('keydown', event => {
    if ((event.metaKey || event.ctrlKey) && event.key === 'k') {
      event.preventDefault()
      overlay?.classList.contains('open') ? closeSearch() : openSearch()
    }
    if (event.key === 'Escape' && overlay?.classList.contains('open')) {
      closeSearch()
    }
    if (overlay?.classList.contains('open')) {
      if (event.key === 'ArrowDown') {
        event.preventDefault()
        selectedIdx = Math.min(selectedIdx + 1, filteredResults.length - 1)
        highlightResult(selectedIdx)
      }
      if (event.key === 'ArrowUp') {
        event.preventDefault()
        selectedIdx = Math.max(selectedIdx - 1, 0)
        highlightResult(selectedIdx)
      }
      if (event.key === 'Enter' && selectedIdx >= 0 && filteredResults[selectedIdx]) {
        closeSearch()
        navigate('ficha', filteredResults[selectedIdx].id)
      }
    }
  })

  searchInput?.addEventListener('input', e => {
    selectedIdx = -1
    renderSearchResults(e.target.value)
  })

  function renderSearchResults(query) {
    const q = query.toLowerCase().trim()
    filteredResults = q
      ? searchData.filter(t =>
          t.nombre.toLowerCase().includes(q) ||
          t.definicionCorta.toLowerCase().includes(q)
        )
      : searchData.slice(0, 12)

    if (!searchResultsEl) return

    if (filteredResults.length === 0) {
      const waText = encodeURIComponent(
        `Camaroncito duro, sácame del apuro: mijoooo, quiero que añadas este término a la web porfa: ${query}`
      )
      const waUrl = `https://wa.me/5358884800?text=${waText}`
      searchResultsEl.innerHTML = `
        <div style="padding: 20px; display: flex; flex-direction: column; align-items: center; gap: 12px;">
          <p style="color: var(--text-muted); font-size: 0.8rem; text-align: center;">
            No hay ningún término llamado <strong style="color: var(--text-primary);">"${query}"</strong>
          </p>
          <a
            href="${waUrl}"
            target="_blank"
            rel="noopener noreferrer"
            style="
              display: inline-flex; align-items: center; gap: 8px;
              padding: 10px 16px; border-radius: 10px;
              background: rgba(37,211,102,0.1);
              border: 1px solid rgba(37,211,102,0.35);
              color: #25d366;
              font-size: 0.78rem; font-family: 'Space Mono', monospace;
              text-decoration: none; transition: background 0.15s, box-shadow 0.15s;
            "
            onmouseover="this.style.background='rgba(37,211,102,0.18)';this.style.boxShadow='0 0 12px rgba(37,211,102,0.25)'"
            onmouseout="this.style.background='rgba(37,211,102,0.1)';this.style.boxShadow='none'"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.558 4.118 1.525 5.845L.057 23.5l5.808-1.525A11.944 11.944 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 0 1-5.006-1.373l-.359-.214-3.444.904.92-3.36-.233-.375A9.818 9.818 0 1 1 12 21.818z"/>
            </svg>
            camaroncito duro, sácame del apuro: mijo, quiero que añadas este término a la web porfa: ${query}
          </a>
        </div>`
      return
    }

    const html = filteredResults.map((t, i) => {
      const colorStyle = t.tipo === 'principal'
        ? 'background: rgba(0,229,255,0.1); color: var(--accent-cyan); border: 1px solid rgba(0,229,255,0.3);'
        : 'background: rgba(255,179,0,0.1); color: var(--accent-amber); border: 1px solid rgba(255,179,0,0.3);'
      return `
        <button
          class="search-result-item w-full text-left px-4 py-3 flex items-start gap-3 transition-colors"
          data-result-id="${t.id}"
          data-result-idx="${i}"
          style="border-bottom: 1px solid var(--border);"
        >
          <span class="pill shrink-0 mt-0.5" style="${colorStyle}">${t.tipo}</span>
          <div>
            <div class="font-mono text-sm" style="color: var(--text-primary);">${t.nombre}</div>
            <div class="text-xs mt-0.5 line-clamp-1" style="color: var(--text-muted);">${t.definicionCorta}</div>
          </div>
        </button>`
    }).join('')

    searchResultsEl.innerHTML = html

    searchResultsEl.querySelectorAll('.search-result-item').forEach(btn => {
      btn.addEventListener('click', () => {
        closeSearch()
        navigate('ficha', btn.dataset.resultId)
      })
      btn.addEventListener('mouseenter', () => {
        selectedIdx = parseInt(btn.dataset.resultIdx)
        highlightResult(selectedIdx)
      })
    })
  }

  function highlightResult(idx) {
    searchResultsEl?.querySelectorAll('.search-result-item').forEach((btn, i) => {
      btn.style.background = i === idx ? 'rgba(0,229,255,0.06)' : ''
    })
    const active = searchResultsEl?.querySelector(`[data-result-idx="${idx}"]`)
    active?.scrollIntoView({ block: 'nearest' })
  }

  // ── Hash-based initial routing ────────────────────────────────────────────

  function routeFromHash() {
    const hash = window.location.hash.slice(1)
    if (!hash || hash === 'mapa') {
      navigate('mapa')
    } else if (hash === 'grupos') {
      navigate('grupos')
    } else if (hash.startsWith('grupos/')) {
      const grupoId = hash.slice(7)
      navigate('grupos', grupoId)
    } else if (hash.startsWith('termino/')) {
      const fichaId = hash.slice(8)
      navigate('ficha', fichaId)
    } else {
      navigate('mapa')
    }
  }

  window.addEventListener('popstate', routeFromHash)
  routeFromHash()

  // ── Stagger inicial del mapa ──────────────────────────────────────────────

  document.querySelectorAll('#grupos-grid .stagger-item').forEach((el, i) => {
    el.style.animationDelay = `${i * 0.07}s`
  })

  // ── Export — proxy to the module below ───────────────────────────────────

  window.__exportFicha   = null   // filled by the export module script
  window.__toggleDominado = null  // filled by the progreso module script

  function exportFicha(id, nombre, btn) {
    if (typeof window.__exportFicha === 'function') {
      window.__exportFicha(id, nombre, btn)
    }
  }

</script>

<style>
  /* Override .view to use flex when active */
  .view {
    display: none !important;
    flex-direction: column;
    flex: 1;
    min-height: 0;
  }
  .view.active {
    display: flex !important;
  }
  .hidden-view {
    display: none !important;
  }

  /* Search result hover */
  .search-result-item:hover {
    background: rgba(0, 229, 255, 0.05) !important;
  }

  /* Line clamp utility */
  .line-clamp-1 {
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
  }

  /* Export button active state */
  .export-btn:hover {
    border-color: var(--accent-cyan) !important;
    color: var(--accent-cyan) !important;
  }
  .export-btn.exporting {
    border-color: var(--accent-amber) !important;
    color: var(--accent-amber) !important;
    opacity: 0.8;
    pointer-events: none;
  }
  .export-btn.done {
    border-color: var(--accent-green) !important;
    color: var(--accent-green) !important;
  }
</style>

<!-- ── Export module (separate script — can use import) ──────────────── -->
<script>
  import { toPng } from 'html-to-image'

  async function exportFicha(terminoId: string, nombre: string, btn: HTMLElement) {
    // The ficha content is already in the live DOM, fully rendered with
    // resolved computed styles. We capture it directly — no cloning needed.
    const panel      = document.getElementById(`ficha-${terminoId}`)
    const contentEl  = document.querySelector<HTMLElement>(`[data-export-content="${terminoId}"]`)
    if (!panel || !contentEl) return

    const label = btn.querySelector('.export-btn-label')
    btn.classList.add('exporting')
    if (label) label.textContent = 'Exportando…'

    // ── 1. Temporarily remove scroll-clipping so full height is captured ──
    const prevPanelOverflow   = panel.style.overflow
    const prevPanelHeight     = panel.style.height
    const prevPanelMaxHeight  = panel.style.maxHeight
    panel.style.overflow  = 'visible'
    panel.style.height    = 'auto'
    panel.style.maxHeight = 'none'

    // ── 2. Hide UI controls that shouldn't appear in the image ─────────
    const hidden: HTMLElement[] = []
    contentEl.querySelectorAll<HTMLElement>('[data-action="export-ficha"], .ficha-breadcrumb')
      .forEach(el => { el.style.visibility = 'hidden'; hidden.push(el) })

    try {
      const fullH = contentEl.scrollHeight

      const dataUrl = await toPng(contentEl, {
        backgroundColor: '#0a0e1a',
        pixelRatio: 2,
        // Force capture of the full scroll height, not just the clipped viewport
        height: fullH,
        style: {
          overflow: 'visible',
          height:   fullH + 'px',
        },
      })

      // ── 3. Restore DOM state ────────────────────────────────────────
      panel.style.overflow  = prevPanelOverflow
      panel.style.height    = prevPanelHeight
      panel.style.maxHeight = prevPanelMaxHeight
      hidden.forEach(el => { el.style.visibility = '' })

      // ── 4. Trigger download ─────────────────────────────────────────
      const safeName = nombre
        .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-zA-Z0-9\s-]/g, '')
        .trim().replace(/\s+/g, '-')
        .toLowerCase()

      const link = document.createElement('a')
      link.download = `bioglosario-${safeName}.png`
      link.href = dataUrl
      link.click()

      btn.classList.remove('exporting')
      btn.classList.add('done')
      if (label) label.textContent = '✓ Descargado'
      setTimeout(() => {
        btn.classList.remove('done')
        if (label) label.textContent = 'Exportar'
      }, 2500)

    } catch (err) {
      panel.style.overflow  = prevPanelOverflow
      panel.style.height    = prevPanelHeight
      panel.style.maxHeight = prevPanelMaxHeight
      hidden.forEach(el => { el.style.visibility = '' })
      console.error('[BioGlosario] Export error:', err)
      btn.classList.remove('exporting')
      if (label) label.textContent = 'Error — reintentar'
      setTimeout(() => { if (label) label.textContent = 'Exportar' }, 2000)
    }
  }

  window.__exportFicha = exportFicha
</script>

<!-- ── Progreso de estudio module ────────────────────────────────────── -->
<script>
  import { getDominados, toggleDominado, getProgreso } from '../lib/progreso'

  const TOTAL = 49

  // ── Update all UI surfaces that reflect progreso ─────────────────────────

  function updateProgresoUI() {
    const { dominados, pct } = getProgreso(TOTAL)
    const dominadosSet = getDominados()

    // Header bar + counter
    const bar  = document.getElementById('progreso-bar')
    const text = document.getElementById('progreso-text')
    const pill = document.getElementById('progreso-pill')
    if (bar)  bar.style.width = pct + '%'
    if (text) text.textContent = `${dominados} / ${TOTAL}`
    if (pill) {
      pill.classList.remove('hidden')
      // Color shifts green as pct grows
      const barEl = bar as HTMLElement | null
      if (barEl) {
        barEl.style.background = pct === 100
          ? 'var(--accent-cyan)'
          : pct > 60
            ? 'var(--accent-green)'
            : 'var(--accent-amber)'
      }
      const textEl = text as HTMLElement | null
      if (textEl) {
        textEl.style.color = pct === 100 ? 'var(--accent-cyan)' : 'var(--text-muted)'
      }
    }

    // Dominado buttons on all visible fichas
    document.querySelectorAll<HTMLButtonElement>('[data-action="toggle-dominado"]').forEach(btn => {
      const id = btn.dataset.id!
      const yes = dominadosSet.has(id)
      applyDominadoBtn(btn, yes)
    })

    // Dot on ConceptCards
    document.querySelectorAll<HTMLElement>('[data-action="navigate-ficha"]').forEach(card => {
      const id = card.dataset.id!
      const dot = card.querySelector<HTMLElement>('.dominado-dot')
      if (dot) dot.style.display = dominadosSet.has(id) ? 'block' : 'none'
    })
  }

  function applyDominadoBtn(btn: HTMLButtonElement, isDone: boolean) {
    const label = btn.querySelector('.dominado-label') as HTMLElement | null
    if (isDone) {
      btn.style.borderColor = 'var(--accent-green)'
      btn.style.color       = 'var(--accent-green)'
      btn.style.background  = 'rgba(57,255,20,0.08)'
      if (label) label.textContent = '✓ Dominado'
    } else {
      btn.style.borderColor = 'var(--border)'
      btn.style.color       = 'var(--text-muted)'
      btn.style.background  = 'var(--bg-card)'
      if (label) label.textContent = 'Dominado'
    }
  }

  // ── Toggle handler ────────────────────────────────────────────────────────

  function handleToggleDominado(id: string) {
    toggleDominado(id)
    updateProgresoUI()
  }

  // ── Init ─────────────────────────────────────────────────────────────────

  // Run on load + every time navigate happens
  window.__toggleDominado = handleToggleDominado
  updateProgresoUI()

  // Re-run after navigation so newly-visible fichas get correct state
  const _origNavigate = (window as any).__bioNavigate
  ;(window as any).__bioNavigate = (view: string, id?: string) => {
    _origNavigate?.(view, id)
    requestAnimationFrame(updateProgresoUI)
  }
</script>
