---
export interface Props {
  title?: string
  description?: string
}

const {
  title = 'BioGlosario — Biopsia Líquida y Parasitología',
  description = 'Glosario interactivo del TFM sobre biopsia líquida y su potencial diagnóstico en enfermedades parasitarias'
} = Astro.props
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
