---
import SearchBar from '../ui/SearchBar.astro'
---

<header
  class="flex items-center justify-between px-4 py-3 shrink-0 z-10"
  style="background: rgba(10,14,26,0.8); border-bottom: 1px solid var(--border); backdrop-filter: blur(10px);"
>
  <!-- Logo -->
  <button
    class="flex items-center gap-2 group"
    data-action="navigate"
    data-view="mapa"
    aria-label="Inicio — Mapa de relaciones"
  >
    <div
      class="w-8 h-8 rounded-lg flex items-center justify-center text-lg glow-cyan"
      style="background: rgba(0,229,255,0.1); border: 1px solid rgba(0,229,255,0.3);"
    >
      🧬
    </div>
    <div class="flex flex-col leading-none">
      <span class="font-mono text-sm font-bold" style="color: var(--accent-cyan);">BioGlosario</span>
      <span class="text-xs" style="color: var(--text-muted);">Biopsia Líquida · TFM</span>
    </div>
  </button>

  <!-- Nav -->
  <nav class="hidden md:flex items-center gap-1">
    <button
      class="nav-btn px-3 py-1.5 rounded-lg text-sm font-mono transition-all"
      data-action="navigate"
      data-view="mapa"
      data-nav="mapa"
    >
      Mapa
    </button>
    <button
      class="nav-btn px-3 py-1.5 rounded-lg text-sm font-mono transition-all"
      data-action="navigate"
      data-view="grupos"
      data-nav="grupos"
    >
      Grupos
    </button>
  </nav>

  <!-- Search -->
  <SearchBar />
</header>

<style>
  .nav-btn {
    color: var(--text-muted);
    background: transparent;
    border: 1px solid transparent;
  }
  .nav-btn:hover,
  .nav-btn.active {
    color: var(--accent-cyan);
    background: rgba(0, 229, 255, 0.08);
    border-color: rgba(0, 229, 255, 0.2);
  }
</style>
