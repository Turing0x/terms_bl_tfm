---
import SearchBar from '../ui/SearchBar.astro'
---

<header
  class="flex items-center justify-between px-4 py-3 shrink-0 z-10"
  style="background: rgba(10,14,26,0.8); border-bottom: 1px solid var(--border); backdrop-filter: blur(10px);"
>
  <!-- Logo -->
  <button
    class="flex items-center gap-2 group"
    data-action="navigate"
    data-view="mapa"
    aria-label="Inicio — Mapa de relaciones"
  >
    <div
      class="w-8 h-8 rounded-lg flex items-center justify-center text-lg glow-cyan"
      style="background: rgba(0,229,255,0.1); border: 1px solid rgba(0,229,255,0.3);"
    >
      🧬
    </div>
    <div class="flex flex-col leading-none">
      <span class="font-mono text-sm font-bold" style="color: var(--accent-cyan);">BioGlosario</span>
      <span class="text-xs" style="color: var(--text-muted);">Biopsia Líquida · TFM</span>
    </div>
  </button>

  <!-- Nav -->
  <nav class="hidden md:flex items-center gap-1">
    <button
      class="nav-btn px-3 py-1.5 rounded-lg text-sm font-mono transition-all"
      data-action="navigate"
      data-view="mapa"
      data-nav="mapa"
    >
      Mapa
    </button>
    <button
      class="nav-btn px-3 py-1.5 rounded-lg text-sm font-mono transition-all"
      data-action="navigate"
      data-view="grupos"
      data-nav="grupos"
    >
      Grupos
    </button>
    <button
      class="nav-btn px-3 py-1.5 rounded-lg text-sm font-mono transition-all"
      data-action="navigate"
      data-view="quiz"
      data-nav="quiz"
    >
      Quiz
    </button>
  </nav>

  <!-- Right: search + progress -->
  <div class="flex items-center gap-3">
    <!-- Progress pill -->
    <div
      id="progreso-pill"
      class="hidden md:flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-mono"
      style="background: var(--bg-card); border: 1px solid var(--border);"
      title="Progreso de estudio"
    >
      <div class="relative w-20 h-1.5 rounded-full overflow-hidden" style="background: var(--border);">
        <div
          id="progreso-bar"
          class="absolute inset-y-0 left-0 rounded-full transition-all duration-500"
          style="width: 0%; background: var(--accent-green);"
        ></div>
      </div>
      <span id="progreso-text" style="color: var(--text-muted);">0 / 49</span>
    </div>

    <SearchBar />
  </div>
</header>

<style>
  .nav-btn {
    color: var(--text-muted);
    background: transparent;
    border: 1px solid transparent;
  }
  .nav-btn:hover,
  .nav-btn.active {
    color: var(--accent-cyan);
    background: rgba(0, 229, 255, 0.08);
    border-color: rgba(0, 229, 255, 0.2);
  }
</style>
