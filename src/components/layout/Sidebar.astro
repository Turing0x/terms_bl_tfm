---
import type { Grupo } from '../../types'

export interface Props {
  grupos: Grupo[]
}

const { grupos } = Astro.props
---

<aside
  id="sidebar"
  class="w-56 shrink-0 overflow-y-auto hidden md:flex flex-col gap-1 p-3"
  style="background: var(--bg-secondary); border-right: 1px solid var(--border);"
>
  <p class="font-mono text-xs px-2 py-1 mb-1" style="color: var(--text-muted);">GRUPOS TEMÁTICOS</p>

  {grupos.map(grupo => (
    <button
      class="sidebar-group-btn text-left rounded-lg px-3 py-2 text-sm transition-all"
      data-action="navigate"
      data-view="grupos"
      data-grupo-id={grupo.id}
      data-grupo-btn={grupo.id}
      style={`--grupo-color: ${grupo.color};`}
    >
      <span class="mr-2">{grupo.emoji}</span>
      <span class="font-mono text-xs leading-tight" style="color: var(--text-primary);">
        {grupo.nombre}
      </span>
      <div class="mt-1 text-xs" style="color: var(--text-muted);">
        {grupo.terminosPrincipales.length + grupo.terminosSecundarios.length} términos
      </div>
    </button>
  ))}
</aside>

<style>
  .sidebar-group-btn {
    background: transparent;
    border: 1px solid transparent;
  }
  .sidebar-group-btn:hover,
  .sidebar-group-btn.active {
    background: color-mix(in srgb, var(--grupo-color) 10%, transparent);
    border-color: color-mix(in srgb, var(--grupo-color) 30%, transparent);
  }
</style>
