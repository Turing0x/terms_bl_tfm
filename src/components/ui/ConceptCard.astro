---
import type { Termino, Grupo } from '../../types'

export interface Props {
  termino: Termino
  grupo: Grupo | undefined
}

const { termino, grupo } = Astro.props
const isPrincipal = termino.tipo === 'principal'
const accentColor = grupo?.color ?? 'var(--accent-cyan)'
---

<article
  class="card-hover cursor-pointer rounded-xl p-4 border relative"
  style={`background: var(--bg-card); border-color: ${accentColor}30;`}
  data-action="navigate-ficha"
  data-id={termino.id}
>
  <!-- Dominado indicator dot (shown/hidden by JS) -->
  <div
    class="dominado-dot absolute top-2 right-2 w-2 h-2 rounded-full"
    style="display: none; background: var(--accent-green); box-shadow: 0 0 6px rgba(57,255,20,0.6);"
    title="Dominado"
  ></div>

  <div class="flex items-start justify-between gap-2 mb-2">
    <h3 class="font-mono text-sm leading-tight pr-4" style={`color: ${accentColor}`}>
      {termino.nombre}
    </h3>
    <span
      class="pill shrink-0 text-xs"
      style={isPrincipal
        ? 'background: rgba(0,229,255,0.1); color: var(--accent-cyan); border: 1px solid rgba(0,229,255,0.3);'
        : 'background: rgba(255,179,0,0.1); color: var(--accent-amber); border: 1px solid rgba(255,179,0,0.3);'
      }
    >
      {isPrincipal ? 'principal' : 'secundario'}
    </span>
  </div>
  <p class="text-xs leading-relaxed" style="color: var(--text-muted);">
    {termino.definicionCorta}
  </p>
</article>
