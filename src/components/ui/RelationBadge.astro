---
export interface Props {
  tipo: string
  descripcion?: string
}

const { tipo, descripcion } = Astro.props

const colorMap: Record<string, string> = {
  'originado-por':   'var(--accent-cyan)',
  'es-subtipo-de':   'var(--accent-green)',
  'procede-de':      'var(--accent-green)',
  'vive-en':         'var(--accent-purple)',
  'degradado-por':   '#ff6e40',
  'determina-tamano':'var(--accent-amber)',
  'protegido-por':   'var(--accent-purple)',
  'compuesta-de':    'var(--accent-cyan)',
  'contiene':        'var(--accent-amber)',
  'estudiada-por':   'var(--accent-purple)',
  'estudiado-por':   'var(--accent-purple)',
  'objeto-de-estudio-de': 'var(--accent-purple)',
  'engloba':         'var(--accent-green)',
  'requiere':        '#ff6e40',
  'analiza':         'var(--accent-cyan)',
  'habilita':        'var(--accent-green)',
  'utiliza':         'var(--accent-amber)',
  'usa':             'var(--accent-amber)',
  'combinable-con':  'var(--accent-cyan)',
  'trabaja-con':     'var(--accent-cyan)',
  'realizada-por':   'var(--accent-purple)',
  'origina':         'var(--accent-green)',
  'contamina':       '#ff6e40',
  'altera':          '#ff6e40',
  'libera-contenido-a': 'var(--accent-amber)',
  'detectada-en':    'var(--accent-green)',
}

const color = colorMap[tipo] ?? 'var(--text-muted)'
---

<span
  class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-mono"
  style={`background: ${color}18; color: ${color}; border: 1px solid ${color}40;`}
  title={descripcion}
>
  {tipo}
</span>
