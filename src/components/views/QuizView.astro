---
import type { Grupo } from '../../types'

interface Props {
  grupos: Grupo[]
}

const { grupos } = Astro.props
---

<div id="quiz-container" class="flex flex-col flex-1 min-h-0 overflow-hidden">

  <!-- ── Pantalla 1: Setup (selección de grupo + modo) ───────────────── -->
  <div id="quiz-setup" class="quiz-screen active flex flex-col flex-1 overflow-y-auto px-4 py-6">
    <div class="max-w-2xl mx-auto w-full flex flex-col gap-8">

      <!-- Header -->
      <div>
        <h2 class="font-mono text-2xl font-bold" style="color: var(--accent-cyan);">Modo Quiz</h2>
        <p class="text-sm mt-1" style="color: var(--text-muted);">
          Elige un grupo y el tipo de ejercicio para practicar.
        </p>
      </div>

      <!-- Selector de grupo -->
      <div>
        <p class="text-xs font-mono uppercase tracking-widest mb-3" style="color: var(--text-muted);">
          1 · Elige un grupo
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {grupos.map(g => (
            <button
              class="quiz-group-btn text-left px-4 py-3 rounded-xl transition-all"
              data-action="quiz-select-group"
              data-grupo-id={g.id}
              style={`background: var(--bg-card); border: 1px solid var(--border);`}
            >
              <div class="flex items-center gap-2 mb-1">
                <span class="text-lg">{g.emoji}</span>
                <span class="font-mono text-sm font-semibold" style="color: var(--text-primary);">{g.nombre}</span>
              </div>
              <p class="text-xs" style="color: var(--text-muted);">{g.subtitulo}</p>
            </button>
          ))}
        </div>
      </div>

      <!-- Selector de modo -->
      <div id="quiz-mode-section" class="opacity-30 pointer-events-none transition-all duration-300">
        <p class="text-xs font-mono uppercase tracking-widest mb-3" style="color: var(--text-muted);">
          2 · Elige el modo
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <button
            class="quiz-mode-btn text-left px-4 py-4 rounded-xl transition-all"
            data-action="quiz-start"
            data-mode="flashcard"
            style="background: var(--bg-card); border: 1px solid var(--border);"
          >
            <div class="text-2xl mb-2">🃏</div>
            <div class="font-mono text-sm font-semibold mb-1" style="color: var(--text-primary);">Flashcards</div>
            <div class="text-xs" style="color: var(--text-muted);">Ve el término, voltea para ver la definición y decide si lo sabías.</div>
          </button>
          <button
            class="quiz-mode-btn text-left px-4 py-4 rounded-xl transition-all"
            data-action="quiz-start"
            data-mode="def-to-term"
            style="background: var(--bg-card); border: 1px solid var(--border);"
          >
            <div class="text-2xl mb-2">💡</div>
            <div class="font-mono text-sm font-semibold mb-1" style="color: var(--text-primary);">Definición → Término</div>
            <div class="text-xs" style="color: var(--text-muted);">Lee la definición y elige cuál es el término correcto entre 4 opciones.</div>
          </button>
          <button
            class="quiz-mode-btn text-left px-4 py-4 rounded-xl transition-all"
            data-action="quiz-start"
            data-mode="term-to-def"
            style="background: var(--bg-card); border: 1px solid var(--border);"
          >
            <div class="text-2xl mb-2">📖</div>
            <div class="font-mono text-sm font-semibold mb-1" style="color: var(--text-primary);">Término → Definición</div>
            <div class="text-xs" style="color: var(--text-muted);">Ve el nombre del término y elige la definición correcta entre 4 opciones.</div>
          </button>
        </div>
      </div>

    </div>
  </div>

  <!-- ── Pantalla 2: Pregunta ────────────────────────────────────────── -->
  <div id="quiz-question" class="quiz-screen flex flex-col flex-1 min-h-0">

    <!-- Barra de progreso del quiz -->
    <div class="px-4 py-2 shrink-0" style="border-bottom: 1px solid var(--border);">
      <div class="max-w-2xl mx-auto flex items-center gap-3">
        <div class="flex-1 h-1.5 rounded-full overflow-hidden" style="background: var(--border);">
          <div
            id="quiz-progress-bar"
            class="h-full rounded-full transition-all duration-500"
            style="width: 0%; background: var(--accent-cyan);"
          ></div>
        </div>
        <span id="quiz-progress-text" class="text-xs font-mono shrink-0" style="color: var(--text-muted);">0 / 0</span>
        <button
          class="text-xs font-mono shrink-0 transition-colors"
          style="color: var(--text-muted);"
          data-action="quiz-exit"
        >
          Salir
        </button>
      </div>
    </div>

    <!-- Tarjeta de pregunta -->
    <div class="flex-1 overflow-y-auto flex items-center justify-center px-4 py-6">
      <div class="max-w-xl w-full flex flex-col gap-5">

        <!-- Etiqueta de modo -->
        <div id="quiz-mode-label" class="text-xs font-mono uppercase tracking-widest" style="color: var(--text-muted);"></div>

        <!-- Flashcard -->
        <div id="quiz-flashcard" class="hidden">
          <div
            id="quiz-card"
            class="rounded-2xl px-8 py-10 text-center cursor-pointer select-none transition-all duration-300"
            style="background: var(--bg-card); border: 1px solid var(--border); min-height: 180px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px;"
            data-action="quiz-flip"
          >
            <div id="quiz-card-front">
              <p class="text-xs font-mono uppercase tracking-widest mb-3" style="color: var(--text-muted);">Término</p>
              <p id="quiz-card-term" class="font-mono text-xl font-bold" style="color: var(--accent-cyan);"></p>
              <p class="text-xs mt-4" style="color: var(--text-muted);">Haz clic para ver la definición →</p>
            </div>
            <div id="quiz-card-back" class="hidden">
              <p class="text-xs font-mono uppercase tracking-widest mb-3" style="color: var(--text-muted);">Definición</p>
              <p id="quiz-card-def" class="text-sm leading-relaxed" style="color: var(--text-primary);"></p>
            </div>
          </div>
          <div id="quiz-flashcard-btns" class="hidden flex gap-3 mt-4">
            <button
              class="flex-1 py-3 rounded-xl font-mono text-sm font-semibold transition-all"
              style="background: rgba(57,255,20,0.08); border: 1px solid rgba(57,255,20,0.3); color: var(--accent-green);"
              data-action="quiz-flashcard-answer"
              data-correct="true"
            >
              ✓ La sabía
            </button>
            <button
              class="flex-1 py-3 rounded-xl font-mono text-sm font-semibold transition-all"
              style="background: rgba(255,179,0,0.08); border: 1px solid rgba(255,179,0,0.3); color: var(--accent-amber);"
              data-action="quiz-flashcard-answer"
              data-correct="false"
            >
              ✗ Repasar
            </button>
          </div>
        </div>

        <!-- Multiple choice -->
        <div id="quiz-mc" class="hidden flex flex-col gap-4">
          <div
            class="rounded-2xl px-6 py-6"
            style="background: var(--bg-card); border: 1px solid var(--border);"
          >
            <p class="text-xs font-mono uppercase tracking-widest mb-2" style="color: var(--text-muted);" id="quiz-mc-label"></p>
            <p id="quiz-mc-prompt" class="text-base leading-relaxed" style="color: var(--text-primary);"></p>
          </div>
          <div id="quiz-mc-options" class="flex flex-col gap-2"></div>
        </div>

      </div>
    </div>
  </div>

  <!-- ── Pantalla 3: Resultados ──────────────────────────────────────── -->
  <div id="quiz-results" class="quiz-screen flex flex-col flex-1 overflow-y-auto px-4 py-6">
    <div class="max-w-xl mx-auto w-full flex flex-col gap-6">

      <div class="text-center">
        <div id="quiz-result-emoji" class="text-5xl mb-3">🎉</div>
        <h2 class="font-mono text-2xl font-bold mb-1" style="color: var(--accent-cyan);">¡Quiz completado!</h2>
        <p class="text-sm" style="color: var(--text-muted);" id="quiz-result-grupo"></p>
      </div>

      <!-- Score -->
      <div
        class="rounded-2xl px-6 py-6 text-center"
        style="background: var(--bg-card); border: 1px solid var(--border);"
      >
        <p id="quiz-result-score" class="font-mono text-4xl font-bold mb-2" style="color: var(--accent-green);"></p>
        <p class="text-sm" style="color: var(--text-muted);">respuestas correctas</p>
        <div class="relative w-full h-2 rounded-full overflow-hidden mt-4" style="background: var(--border);">
          <div
            id="quiz-result-bar"
            class="absolute inset-y-0 left-0 rounded-full transition-all duration-700"
            style="width: 0%; background: var(--accent-green);"
          ></div>
        </div>
        <p id="quiz-result-pct" class="text-xs font-mono mt-2" style="color: var(--text-muted);"></p>
      </div>

      <!-- Desglose de errores -->
      <div id="quiz-result-errors" class="hidden flex flex-col gap-2">
        <p class="text-xs font-mono uppercase tracking-widest" style="color: var(--text-muted);">Para repasar</p>
        <div id="quiz-result-errors-list" class="flex flex-col gap-2"></div>
      </div>

      <!-- Acciones -->
      <div class="flex gap-3">
        <button
          class="flex-1 py-3 rounded-xl font-mono text-sm font-semibold transition-all"
          style="background: rgba(0,229,255,0.08); border: 1px solid rgba(0,229,255,0.3); color: var(--accent-cyan);"
          data-action="quiz-retry"
        >
          Reintentar
        </button>
        <button
          class="flex-1 py-3 rounded-xl font-mono text-sm font-semibold transition-all"
          style="background: var(--bg-card); border: 1px solid var(--border); color: var(--text-muted);"
          data-action="quiz-change-group"
        >
          Otro grupo
        </button>
      </div>

    </div>
  </div>

</div>

<style>
  .quiz-screen {
    display: none;
  }
  .quiz-screen.active {
    display: flex;
  }

  .quiz-group-btn:hover,
  .quiz-group-btn.selected {
    border-color: rgba(0, 229, 255, 0.4) !important;
    background: rgba(0, 229, 255, 0.06) !important;
  }
  .quiz-group-btn.selected {
    box-shadow: 0 0 12px rgba(0, 229, 255, 0.12);
  }

  .quiz-mode-btn:hover {
    border-color: rgba(0, 229, 255, 0.3) !important;
    background: rgba(0, 229, 255, 0.06) !important;
  }

  :global(#quiz-mc-options .mc-option) {
    width: 100%;
    text-align: left;
    padding: 12px 16px;
    border-radius: 12px;
    font-size: 0.875rem;
    line-height: 1.5;
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text-primary);
    transition: border-color 0.15s, background 0.15s, color 0.15s, transform 0.1s;
    cursor: pointer;
  }
  :global(#quiz-mc-options .mc-option:hover:not(:disabled)) {
    border-color: rgba(0, 229, 255, 0.45);
    background: rgba(0, 229, 255, 0.09);
    color: var(--text-primary);
    transform: translateX(3px);
  }
  :global(#quiz-mc-options .mc-option.correct) {
    border-color: var(--accent-green) !important;
    background: rgba(57, 255, 20, 0.08) !important;
    color: var(--accent-green) !important;
  }
  :global(#quiz-mc-options .mc-option.wrong) {
    border-color: rgba(255, 80, 80, 0.5) !important;
    background: rgba(255, 80, 80, 0.06) !important;
    color: rgba(255, 80, 80, 0.8) !important;
  }
  :global(#quiz-mc-options .mc-option:disabled) {
    cursor: default;
    opacity: 0.7;
    transform: none;
  }

  #quiz-card:hover {
    border-color: rgba(0, 229, 255, 0.25);
    box-shadow: 0 0 20px rgba(0, 229, 255, 0.08);
  }
</style>
